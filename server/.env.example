# --- Fendi's Food Hut order backend ---
# Copy this file to `.env` and fill in the blanks: cp .env.example .env

# Port the Node server listens on (nginx reverse-proxies 443 -> this)
PORT=8787

# Telegram bot token for @fendi_business_bot (from @BotFather).
# Leave EMPTY for local testing so no real message is sent.
BOT_TOKEN=

# Telegram chat id of the orders group (already preset — the bot is in it).
ORDERS_CHAT_ID=-1003785384757

# Optional mention appended to every order message so Robert gets pinged.
# e.g. @robert  (or an HTML mention: <a href="tg://user?id=123456">Robert</a>)
ROBERT_MENTION=

# HTTP Basic auth credentials for the /admin panel + /api/orders endpoints.
# CHANGE ADMIN_PASS to something strong before going live.
ADMIN_USER=robert
ADMIN_PASS=change-me

# Which website origin is allowed to POST orders (CORS).
CORS_ORIGIN=https://fendithefrenchie.com
